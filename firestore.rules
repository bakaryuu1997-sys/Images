rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Catch-all Safeguard
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation blueprints
    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.createdAt is string
        && isOwner(data.userId);
    }

    function isValidImage(data) {
      return data.id is string && data.id.size() <= 128
        && data.url is string && data.url.size() <= 15728640 // 15MB limit
        && data.prompt is string && data.prompt.size() <= 2000
        && data.createdAt is string
        && data.isFavorite is bool
        && isOwner(data.userId);
    }

    function isValidAsset(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.token is string && data.token.size() <= 500
        && isOwner(data.userId);
    }

    // Match patterns
    match /projects/{projectId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /images/{imageId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(imageId) && isValidImage(request.resource.data);
      allow update: if isSignedIn() && isValidId(imageId) && isValidImage(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.url == resource.data.url; // url is immutable
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /assets/{assetId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(assetId) && isValidAsset(request.resource.data);
      allow update: if isSignedIn() && isValidId(assetId) && isValidAsset(request.resource.data)
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
